# =============================================================================
# .env.example — Environment Variables Template
# =============================================================================
# Copy this file to .env and customize the values
# =============================================================================

# =============================================================================
# Version Configuration / 版本配置
# =============================================================================
VERSION=latest
PULL_POLICY=if-not-present

# GitHub Organization for GHCR (optional)
# GitHub 组织名称（可选）
GITHUB_ORG=ertu426

# =============================================================================
# Port Configuration / 端口配置
# =============================================================================
# Default container ports
DEFAULT_HTTP_PORT=30080
DEFAULT_SSH_PORT=30022

# Cangjie container ports
CANGJIE_HTTP_PORT=30180
CANGJIE_SSH_PORT=30122

# =============================================================================
# Resource Limits / 资源限制
# =============================================================================
DEFAULT_CPU_LIMIT=2
DEFAULT_MEM_LIMIT=4G
CANGJIE_CPU_LIMIT=2
CANGJIE_MEM_LIMIT=4G

# =============================================================================
# Timezone / 时区
# =============================================================================
TZ=Asia/Shanghai

# =============================================================================
# Code Server Password / Code Server 密码
# =============================================================================
# ⚠️ IMPORTANT: Change this in production!
# ⚠️ 重要：请在生产环境中修改！
CODE_SERVER_PASSWORD=dev123456

# =============================================================================
# SSH Configuration / SSH 配置
# =============================================================================
# Uncomment and set to enable SSH agent forwarding
# 取消注释并设置以启用 SSH 密钥转发
# SSH_AUTH_SOCK=/your/path/to/ssh-agent.sock
