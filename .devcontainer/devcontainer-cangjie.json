{
  "name": "DGen Cangjie Development Container",
  "dockerComposeFile": [
    "../docker-compose.yaml"
  ],
  "service": "cangjie-develop",
  "workspaceFolder": "/home/dev/workspace",
  "shutdownAction": "stopCompose",
  
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "true"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },

  "forwardPorts": [
    8080,
    2222
  ],

  "portsAttributes": {
    "8080": {
      "label": "Code Server",
      "onAutoForward": "openBrowser"
    },
    "2222": {
      "label": "SSH",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "settings": {
        // Editor
        "editor.fontSize": 14,
        "editor.fontFamily": "'Cascadia Code', 'JetBrains Mono', Consolas, monospace",
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.formatOnSave": true,
        
        // Terminal
        "terminal.integrated.fontSize": 13,
        "terminal.integrated.defaultProfile.linux": "fish",
        
        // Workbench
        "workbench.colorTheme": "Default Dark+",
        "workbench.iconTheme": "material-icon-theme",
        
        // Cangjie specific
        "[cangjie]": {
          "editor.defaultFormatter": "huaouo.cangjie-language-support"
        },
        
        // Chinese UI
        "locale": "zh-cn"
      },
      "extensions": [
        // Theme
        "GitHub.github-theme",
        "Equinusocio.vsc-material-theme",
        "PKief.material-icon-theme",
        
        // Cangjie Language Support (Essential)
        "huaouo.cangjie-language-support",
        
        // Python (uv)
        "ms-python.python",
        "ms-python.vscode-pylance",
        
        // General
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens",
        
        // Productivity
        "usernamehw.errorlens",
        "christian-kohler.path-intellisense"
      ]
    }
  },

  "remoteEnv": {
    "LANG": "zh_CN.UTF-8",
    "LC_ALL": "zh_CN.UTF-8",
    "LANGUAGE": "zh_CN:zh:en",
    "CANGJIE_HOME": "/home/dev/cangjie",
    "CANGJIE_SDKX_HOME": "/home/dev/cangjie_sdkx"
  },

  "remoteUser": "dev",
  "postCreateCommand": "fish -c 'cjc --version && echo \"Cangjie environment ready!\"'",

  "containerEnv": {
    "SHELL": "/usr/bin/fish",
    "CANGJIE_HOME": "/home/dev/cangjie",
    "CANGJIE_SDKX_HOME": "/home/dev/cangjie_sdkx"
  },

  "annotations": {
    "org.opencontainers.image.description": "DGen Cangjie Development Container - Programming language development environment with Cangjie SDK, stdx, and Chinese UI support",
    "org.opencontainers.image.description.zh": "DGen 仓颉开发容器 - 预装仓颉 SDK、标准库和 uv，支持中文界面",
    "org.opencontainers.image.vendor": "DGen",
    "org.opencontainers.image.version": "1.0.0"
  }
}
