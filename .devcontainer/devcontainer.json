{
  "name": "DGen Development Container",
  "dockerComposeFile": [
    "../docker-compose.yaml"
  ],
  "service": "default-develop",
  "workspaceFolder": "/home/dev/workspace",
  "shutdownAction": "stopCompose",
  
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "true"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },

  "forwardPorts": [
    8080,
    2222
  ],

  "portsAttributes": {
    "8080": {
      "label": "Code Server",
      "onAutoForward": "openBrowser"
    },
    "2222": {
      "label": "SSH",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "settings": {
        // Editor
        "editor.fontSize": 14,
        "editor.fontFamily": "'Cascadia Code', 'JetBrains Mono', Consolas, monospace",
        "editor.fontLigatures": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.formatOnSave": true,
        "editor.minimap.enabled": true,
        "editor.lineNumbers": "on",
        "editor.renderWhitespace": "boundary",
        "editor.bracketPairColorization.enabled": true,
        "editor.guides.bracketPairs": true,
        
        // Terminal
        "terminal.integrated.fontSize": 13,
        "terminal.integrated.fontFamily": "'Cascadia Code', 'Fira Code', monospace",
        "terminal.integrated.defaultProfile.linux": "fish",
        
        // Window
        "window.restoreWindows": "all",
        "window.newWindowDimensions": "inherit",
        
        // Workbench
        "workbench.colorTheme": "Default Dark+",
        "workbench.iconTheme": "material-icon-theme",
        "workbench.startupEditor": "welcomePage",
        "workbench.editor.enablePreview": false,
        
        // Files
        "files.autoSave": "afterDelay",
        "files.autoSaveDelay": 1000,
        "files.insertFinalNewline": true,
        "files.trimTrailingWhitespace": true,
        
        // Git
        "git.enableSmartCommit": true,
        "git.confirmSync": false,
        "git.autofetch": true,
        
        // Remote
        "remote.SSH.showLoginTerminal": true,
        "remote.SSH.configFile": "~/.ssh/config",
        
        // Chinese UI
        "locale": "zh-cn"
      },
      "extensions": [
        // Theme
        "GitHub.github-theme",
        "Equinusocio.vsc-material-theme",
        "PKief.material-icon-theme",
        
        // Essential
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens",
        
        // DevOps
        "ms-azuretools.vscode-docker",
        "ms-vscode.powershell",
        
        // Productivity
        "usernamehw.errorlens",
        "visualstudioexptteam.vscodeintellicode",
        "christian-kohler.path-intellisense",
        
        // Cangjie Language Support
        "huaouo.cangjie-language-support"
      ]
    }
  },

  "remoteEnv": {
    "LANG": "zh_CN.UTF-8",
    "LC_ALL": "zh_CN.UTF-8",
    "LANGUAGE": "zh_CN:zh:en"
  },

  "remoteUser": "dev",
  "postCreateCommand": "fish -c 'echo \"Development environment ready!\"'",

  "initializeCommand": [
    "mkdir -p ~/.ssh",
    "if [ ! -f ~/.ssh/id_rsa ]; then ssh-keygen -t rsa -b 4096 -C \"dev@container\" -N \"\" -f ~/.ssh/id_rsa; fi"
  ],

  "containerEnv": {
    "SHELL": "/usr/bin/fish"
  },

  "annotations": {
    "org.opencontainers.image.description": "DGen Development Container - Universal development environment with Code Server and Chinese UI support",
    "org.opencontainers.image.description.zh": "DGen 开发容器 - 预装 Code Server，支持中文界面的通用开发环境",
    "org.opencontainers.image.vendor": "DGen",
    "org.opencontainers.image.version": "1.0.0"
  }
}
